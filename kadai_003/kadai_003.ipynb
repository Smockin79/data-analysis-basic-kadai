        "# Step1\n",
        "import numpy as np\n",
        "\n",
        "# Step2\n",
        "A = np.array([\n",
        "    [0, 1],\n",
        "    [2, 3],\n",
        "    [4, 5]\n",
        "])\n",
        "\n",
        "B = np.array([\n",
        "    [0, 1, 2, 3],\n",
        "    [4, 5, 6, 7]\n",
        "])\n",
        "\n",
        "# Step3\n",
        "result = np.dot(A, B)\n",
        "\n",
        "# Step4\n",
        "print(result)\n",
        "\n",
        "# Step5\n",
        "print(result.max())"
      ],
